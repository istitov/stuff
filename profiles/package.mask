# Ivan S. Titov <iohann.s.titov@gmail.com> (2026-04-20)
# IPX was removed from the Linux kernel in 4.18 (2018). Userspace utils
# are only useful with the out-of-tree ipx module. Keep but mask.
net-misc/ipx-utils

# Ivan S. Titov <iohann.s.titov@gmail.com> (2026-04-20)
# Upstream (github.com/megabaks) dormant since 2014-02. No tagged
# release, 9999-only. Keep but mask.
app-portage/portopts

# Ivan S. Titov <iohann.s.titov@gmail.com> (2026-04-22)
# ::gentoo qscintilla-2.14.1-r2 is Qt6-only; sci-physics/mantid needs
# the Qt5 variant that only -r1 still provides (revived in this overlay).
# Drop this mask once mantid moves to Qt6.
=x11-libs/qscintilla-2.14.1-r2

# Ivan S. Titov <iohann.s.titov@gmail.com> (2026-05-06)
# Vulnerable to CVE-2026-31431 ("Copy Fail" algif_aead local privilege
# escalation, CVSS 7.8). The pf-kernel patchset is GA-only; these
# ebuilds ship vanilla v6.X.0 + pf without linux-stable backports, so
# the upstream revert that fixes the bug never reaches them. Migrate
# to the same slot's -r1 ebuild (verbatim natalenko + surgical CVE
# patch) or to sys-kernel/pf-sources-extended (curated pf delta on top
# of gentoo-sources, tracking linux-stable). Mask is part of a 30-day
# lastrite cycle; ebuilds stay in tree as a recovery path with
# KEYWORDS="" from 2026-06-05.
# See news item 2026-05-06-pf-sources-changes for context.
=sys-kernel/pf-sources-6.16_p5
=sys-kernel/pf-sources-6.17_p4
=sys-kernel/pf-sources-6.18_p6
=sys-kernel/pf-sources-6.19_p5


# Ivan S. Titov <iohann.s.titov@gmail.com> (2026-05-16)
# Two-minor-lines-back; retained as a recovery ebuild but blocked from
# default install. Drop after a few months of 0.7.x being stable, or
# remove this mask if 0.5.x rollback becomes relevant again.
=app-portage/udept-0.5.99.0.2.96
