-            hopper/flash_api.cpp
-            hopper/flash_api_torch_lib.cpp
-            ${FA3_GEN_SRCS}
-        COMPILE_FLAGS ${VLLM_FA_GPU_FLAGS}
-        ARCHITECTURES "" # LucasW: this is ignored for cuda and set on a per-file basis
-        USE_SABI 3
-        WITH_SOABI)
+    if(FA3_ARCHS)
