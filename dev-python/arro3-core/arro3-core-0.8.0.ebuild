inherit cargo distutils-r1 pypi

DESCRIPTION="Lightweight Rust-backed Arrow implementation for Python"
HOMEPAGE="
	https://github.com/kylebarron/arro3
	https://pypi.org/project/arro3-core/
"
SRC_URI+=" ${CARGO_CRATE_URIS}"
S="${WORKDIR}/${PN/-/_}-${PV}"

# arro3-core itself is dual-licensed; transitive crate licenses below.
LICENSE="|| ( MIT Apache-2.0 )"
# Dependent crate licenses
LICENSE+="
	Apache-2.0 Apache-2.0-with-LLVM-exceptions BSD BSD-2 BSL-1.0
	CC0-1.0 ISC MIT MPL-2.0 Unicode-3.0 Unicode-DFS-2016 ZLIB
"
SLOT="0"
KEYWORDS="~amd64"

RDEPEND="
	$(python_gen_cond_dep '
		>=dev-python/typing-extensions-4.0[${PYTHON_USEDEP}]
	' python3_11)
"

# No upstream tests in sdist.
RESTRICT="test"
