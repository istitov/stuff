@@ -1314,7 +1314,6 @@
                 .samplerate = fileinfo->fmt.samplerate,
                 .channelmask = fileinfo->fmt.channelmask,
                 .is_float = 1,
-                .is_bigendian = 0
             };
 
             int eof = 0;
@@ -1723,7 +1722,7 @@
 }
 
