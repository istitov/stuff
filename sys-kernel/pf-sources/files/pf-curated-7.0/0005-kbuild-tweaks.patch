From: Oleksandr Natalenko <oleksandr@natalenko.name>
Subject: [pf-curated-7.0] kbuild: build-system tweaks

Re-cut from natalenko's pf-kernel branch kbuild-7.0 (tip 30b7ebebc5d5)
as a single bulk diff, restricted to the files this overlay's curation
kept on the 7.0 active slot. Source: codeberg.org/pf-kernel/linux.

Two-file kbuild tweaks (arch/x86/Kconfig.cpu + arch/x86/Makefile),
mirroring 6.18's pattern.
---
diff --git a/arch/x86/Kconfig.cpu b/arch/x86/Kconfig.cpu
index f928cf6e32..96750ac837 100644
--- a/arch/x86/Kconfig.cpu
+++ b/arch/x86/Kconfig.cpu
@@ -281,6 +281,15 @@ config X86_GENERIC
 	  This is really intended for distributors who need more
 	  generic optimizations.
 
+config X86_64_ISA_LEVEL
+	int "x86_64 ISA level"
+	range 1 3
+	depends on (CC_IS_GCC && GCC_VERSION > 110000) || (CC_IS_CLANG && CLANG_VERSION >= 120000)
+	depends on X86_64
+	depends on !X86_NATIVE_CPU
+	help
+	  Specify an x86_64 ISA level.
+
 #
 # Define implied options from the CPU selection here
 config X86_INTERNODE_CACHE_SHIFT
diff --git a/arch/x86/Makefile b/arch/x86/Makefile
index 5f881460a8..5827631c80 100644
--- a/arch/x86/Makefile
+++ b/arch/x86/Makefile
@@ -77,7 +77,7 @@ export BITS
 #
 #    https://gcc.gnu.org/bugzilla/show_bug.cgi?id=53383
 #
-KBUILD_CFLAGS += -mno-sse -mno-mmx -mno-sse2 -mno-3dnow -mno-avx -mno-sse4a
+KBUILD_CFLAGS += -mno-sse -mno-mmx -mno-sse2 -mno-3dnow -mno-avx -mno-sse4a -mno-avx2 -fno-tree-vectorize
 KBUILD_RUSTFLAGS += --target=$(objtree)/scripts/target.json
 KBUILD_RUSTFLAGS += -Ctarget-feature=-sse,-sse2,-sse3,-ssse3,-sse4.1,-sse4.2,-avx,-avx2
 
@@ -168,8 +168,13 @@ ifdef CONFIG_X86_NATIVE_CPU
         KBUILD_CFLAGS += -march=native
         KBUILD_RUSTFLAGS += -Ctarget-cpu=native
 else
+    ifeq ($(CONFIG_X86_64_ISA_LEVEL),1)
         KBUILD_CFLAGS += -march=x86-64 -mtune=generic
         KBUILD_RUSTFLAGS += -Ctarget-cpu=x86-64 -Ztune-cpu=generic
+    else
+	KBUILD_CFLAGS += -march=x86-64-v$(CONFIG_X86_64_ISA_LEVEL)
+	KBUILD_RUSTFLAGS += -Ctarget-cpu=x86-64-v$(CONFIG_X86_64_ISA_LEVEL)
+    endif
 endif
 
         KBUILD_CFLAGS += -mno-red-zone
